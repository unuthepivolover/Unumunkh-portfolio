<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Unumunkh — Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #f5f3ef;
      --surface:  #ffffff;
      --text:     #1a1a1a;
      --muted:    #6b6b6b;
      --accent:   #3d5a47;
      --line:     #ddd9d3;
      --serif:    'DM Serif Display', serif;
      --sans:     'DM Sans', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-weight: 300;
      line-height: 1.7;
    }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 4rem;
      background: rgba(245,243,239,0.88);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
    }

    .nav-logo {
      font-family: var(--serif);
      font-size: 1.3rem;
      color: var(--text);
      text-decoration: none;
      letter-spacing: 0.01em;
    }

    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: 0.85rem;
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--muted);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--accent); }

    /* SECTIONS */
    section { min-height: 100vh; padding: 8rem 4rem 5rem; }

    /* HOME */
    #home {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 4rem;
    }

    .home-text h1 {
      font-family: var(--serif);
      font-size: clamp(2.8rem, 5vw, 4.5rem);
      line-height: 1.15;
      margin-bottom: 1rem;
    }

    .home-text .subtitle {
      font-size: 1rem;
      color: var(--muted);
      margin-bottom: 0.5rem;
      letter-spacing: 0.04em;
    }

    .home-text .school {
      display: inline-block;
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid var(--accent);
      padding: 0.3rem 0.8rem;
      border-radius: 2rem;
      margin-top: 1.5rem;
    }

    .home-img {
      display: flex; justify-content: center; align-items: center;
    }

    .photo-frame {
      width: 340px; height: 400px;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 12px 40px rgba(0,0,0,0.08);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 0.75rem;
    }

    .photo-frame img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: top;
    }

    .photo-placeholder {
      text-align: center; color: var(--muted); font-size: 0.85rem;
    }
    .photo-placeholder svg { opacity: 0.3; margin-bottom: 0.5rem; display: block; margin-inline: auto; }

    /* DIVIDER LABEL */
    .section-label {
      display: flex; align-items: center; gap: 1rem;
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 3.5rem;
    }
    .section-label::after {
      content: ''; flex: 1; height: 1px; background: var(--line);
    }

    /* ABOUT */
    #about { background: var(--surface); }

    .about-grid {
      display: grid; grid-template-columns: 1fr 1.4fr; gap: 5rem;
      align-items: start;
    }

    .about-stat { margin-bottom: 2.5rem; }
    .about-stat .num {
      font-family: var(--serif); font-size: 3.5rem; color: var(--accent);
      line-height: 1;
    }
    .about-stat .label {
      font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--muted); margin-top: 0.25rem;
    }

    .about-bio h2 {
      font-family: var(--serif); font-size: 2.2rem; margin-bottom: 1.25rem;
    }
    .about-bio p { color: var(--muted); margin-bottom: 1rem; }

    /* CLASSES */
    #classes { background: var(--bg); }

    .classes-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
      gap: 1.25rem;
    }

    .class-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 1.75rem;
      transition: transform 0.25s, box-shadow 0.25s;
    }
    .class-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.07);
    }
    .class-card .icon { font-size: 1.5rem; margin-bottom: 1rem; }
    .class-card h3 { font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem; }
    .class-card p { font-size: 0.82rem; color: var(--muted); }

    /* HOBBIES */
    #hobbies { background: var(--surface); }

    .hobby-row {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
    }

    .hobby-block {
      border: 1px solid var(--line); border-radius: 8px; padding: 2.5rem;
      position: relative; overflow: hidden;
    }

    .hobby-block .big-icon {
      position: absolute; right: 1.5rem; bottom: 1rem;
      font-size: 5rem; opacity: 0.06; user-select: none;
    }

    .hobby-block h3 {
      font-family: var(--serif); font-size: 1.6rem; margin-bottom: 0.75rem;
    }
    .hobby-block p { font-size: 0.88rem; color: var(--muted); max-width: 26ch; }

    /* CONTACT */
    #contact {
      background: var(--accent); color: #e8f0eb;
      display: flex; flex-direction: column;
      justify-content: center; align-items: flex-start;
    }

    #contact .section-label { color: rgba(232,240,235,0.55); }
    #contact .section-label::after { background: rgba(232,240,235,0.2); }

    #contact h2 {
      font-family: var(--serif);
      font-size: clamp(2.5rem, 5vw, 4rem);
      margin-bottom: 2.5rem; color: #fff;
    }

    .contact-items { display: flex; flex-direction: column; gap: 1.25rem; }

    .contact-item {
      display: flex; align-items: center; gap: 1rem;
      font-size: 1rem; color: rgba(232,240,235,0.85);
    }
    .contact-item .ci-icon {
      width: 42px; height: 42px; border-radius: 50%;
      background: rgba(255,255,255,0.1);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; flex-shrink: 0;
    }
    .contact-item a { color: inherit; text-decoration: none; }
    .contact-item a:hover { text-decoration: underline; }

    /* FOOTER */
    footer {
      text-align: center; padding: 2rem;
      font-size: 0.78rem; color: var(--muted);
      border-top: 1px solid var(--line);
      background: var(--bg);
    }

    /* FADE IN */
    .fade-up {
      opacity: 0; transform: translateY(24px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-up.visible { opacity: 1; transform: none; }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { gap: 1.25rem; }
      section { padding: 7rem 1.5rem 4rem; }
      #home { grid-template-columns: 1fr; text-align: center; }
      .home-img { justify-content: center; }
      .about-grid { grid-template-columns: 1fr; gap: 2rem; }
      .hobby-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

